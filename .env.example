# ─────────────────────────────────────────────────────────────────
# Ask Umang chat — required & optional env vars
# Copy this to .env.local and fill in. Anything left blank silently
# disables that feature so dev still works.
# ─────────────────────────────────────────────────────────────────

# REQUIRED — chat won't respond without this.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# RECOMMENDED — embedding-based retrieval for the lookup_detail tool.
# Without it, falls back to keyword dict lookup. ~$0.0001 to embed
# the entire knowledge base. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# RECOMMENDED — Telegram push notifications when a lead drops their
# email or the bot can't answer. Reply from your phone.
# Setup (5 min):
#   1. Telegram → @BotFather → /newbot → follow prompts.
#   2. Copy the bot token here.
#   3. Send your new bot any message ("hi"), then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy
#      the "chat":{"id": ...} number.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OPTIONAL — Email backup via Resend (free tier: 3000/mo).
# https://resend.com — verify your domain to send from your address.
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_EMAIL=umanggarg28@gmail.com

# OPTIONAL — Upstash Redis for cross-instance rate limiting.
# Without this, the limiter falls back to per-instance in-memory
# (fine for single-region Vercel; resets on cold start).
# Either pair works (Vercel KV auto-injects the KV_* aliases):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# OPTIONAL — Langfuse observability (per-stage traces, online scoring,
# prompt versioning). Without these, instrumentation no-ops cleanly.
# Free tier: 50k observations/mo. https://langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_PROMPT_NAME=umang-chat-system

# OPTIONAL — flip to "true" to enable per-response Sonnet scoring
# (quality / safety / in_voice). Adds ~$0.001 per chat. Off by default.
ENABLE_ONLINE_SCORING=

# OPTIONAL — passcode for the /ops dashboard. If unset, /ops returns 503.
OPS_PASSCODE=

# OPTIONAL — secret for prompt regression overrides. Lets the
# x-prompt-version + x-prompt-auth headers swap in a specific
# Langfuse prompt version for A/B comparison.
PROMPT_REGRESSION_SECRET=
